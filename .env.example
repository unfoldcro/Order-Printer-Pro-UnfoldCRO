# ─────────────────────────────────────────────────────────────
# ORDER DOCS PRINTER — Environment Variables
# Copy this file to .env and fill in every value below.
# NEVER commit the .env file to version control.
# ─────────────────────────────────────────────────────────────

# ── Shopify App Credentials ───────────────────────────────────
# Found at: https://partners.shopify.com → Apps → [Your App] → App setup
#
# API key (also called "Client ID") — public identifier for your app.
SHOPIFY_API_KEY=your_api_key_here
#
# API secret (also called "Client secret") — keep this private.
SHOPIFY_API_SECRET=your_api_secret_here

# ── Shopify OAuth Scopes ──────────────────────────────────────
# Comma-separated list of access scopes your app requests.
# Do NOT add spaces between scopes.
# Required scopes for this app:
#   read_orders    — read order data for PDF generation
#   read_customers — read customer email for auto-send
SCOPES=read_orders,read_customers

# ── App Public URL ────────────────────────────────────────────
# The publicly accessible HTTPS URL where this app is hosted.
# Local development: use a tunnel tool such as ngrok or Cloudflare Tunnel.
#   Example (ngrok):       https://abc123.ngrok.io
#   Example (production):  https://order-docs.fly.dev
# This value must match the "App URL" set in your Shopify Partner Dashboard.
SHOPIFY_APP_URL=https://order-printer-pro-unfoldcro.onrender.com

# ── PostgreSQL Database ───────────────────────────────────────
# Full connection string for your PostgreSQL database.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
#
# Local example:      postgresql://postgres:secret@localhost:5432/order_docs_printer
# Fly.io example:     postgresql://user:pass@fly-db.internal:5432/order_docs_printer
# Railway example:    postgresql://postgres:pass@containers-us-west-1.railway.app:6543/railway
# Supabase example:   postgresql://postgres:pass@db.xxxx.supabase.co:5432/postgres
DATABASE_URL=postgresql://user:password@localhost:5432/order_docs_printer

# ── SendGrid (Email Provider) ─────────────────────────────────
# Required only when auto-send email is enabled in Settings.
# Get your API key at: https://app.sendgrid.com/settings/api_keys
#   1. Click "Create API Key"
#   2. Choose "Restricted Access" → enable "Mail Send"
#   3. Copy the key (starts with "SG.")
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
